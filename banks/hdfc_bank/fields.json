{
  "accountSections": [
    {
      "title": "Account Holder",
      "fields": [
        { "key": "customer_name", "label": "Full Name", "required": true, "span": 2, "placeholder": "e.g. MS THUNGA YOSHITHA" },
        { "key": "address_line_1", "label": "Address Line 1" },
        { "key": "address_line_2", "label": "Address Line 2" },
        { "key": "city_state", "label": "City / State" },
        { "key": "pin", "label": "PIN Code" },
        { "key": "state_country", "label": "State / Country", "placeholder": "e.g. KARNATAKA INDIA" },
        { "key": "email", "label": "Email" },
        { "key": "nominee", "label": "Nominee", "placeholder": "e.g. Registered" },
        { "key": "joint_holders", "label": "Joint Holders" }
      ]
    },
    {
      "title": "Account Information",
      "fields": [
        { "key": "account_number", "label": "Account Number", "required": true },
        { "key": "account_type", "label": "Account Type", "required": true },
        { "key": "account_variant", "label": "Account Variant", "placeholder": "e.g. VIRTUAL IMPERIA" },
        { "key": "account_status", "label": "Account Status", "placeholder": "e.g. Regular" },
        { "key": "ac_open_date", "label": "A/C Open Date", "placeholder": "DD/MM/YYYY" },
        { "key": "cust_id", "label": "Customer ID" }
      ]
    },
    {
      "title": "Branch Details",
      "fields": [
        { "key": "branch", "label": "Branch Name", "required": true },
        { "key": "branch_code", "label": "Branch Code" },
        { "key": "ifsc", "label": "RTGS/NEFT IFSC" },
        { "key": "micr", "label": "MICR Code" },
        { "key": "branch_address_1", "label": "Branch Address Line 1", "placeholder": "e.g. WARD NO.151, 80 FEET ROAD,4TH BLOCK" },
        { "key": "branch_address_2", "label": "Branch Address Line 2", "placeholder": "e.g. KORAMANGALA, BANGALORE 560034" },
        { "key": "branch_address_3", "label": "Branch Address Line 3", "placeholder": "e.g. LANDMARK NEXT TO STARBUCKS CAFE" },
        { "key": "branch_city", "label": "Branch City", "placeholder": "e.g. BENGALURU 560034" },
        { "key": "branch_state", "label": "Branch State", "placeholder": "e.g. KARNATAKA" },
        { "key": "phone", "label": "Phone No.", "placeholder": "e.g. 18002600/18001600" }
      ]
    },
    {
      "title": "Balance & Currency",
      "fields": [
        { "key": "current_balance", "label": "Current Balance", "required": true, "mono": true },
        { "key": "overdraft", "label": "OD Limit", "mono": true },
        { "key": "currency", "label": "Currency" }
      ]
    },
    {
      "title": "Statement Metadata",
      "fields": [
        { "key": "generated_on", "label": "Generated On" },
        { "key": "generated_by", "label": "Generated By" },
        { "key": "requesting_branch_code", "label": "Requesting Branch Code" }
      ]
    }
  ],
  "transactionColumns": [
    { "key": "date",       "label": "Date",            "type": "date",   "width": "w-28" },
    { "key": "description","label": "Narration",       "type": "text",   "flex": true },
    { "key": "ref",        "label": "Chq./Ref.No.",    "type": "text",   "width": "w-32" },
    { "key": "value_date", "label": "Value Dt",        "type": "date",   "width": "w-28" },
    { "key": "debit",      "label": "Withdrawal Amt.", "type": "amount", "width": "w-32", "color": "red" },
    { "key": "credit",     "label": "Deposit Amt.",    "type": "amount", "width": "w-28", "color": "green" },
    { "key": "balance",    "label": "Closing Balance", "type": "amount", "width": "w-32", "readonly": true }
  ],
  "csvHeaders": "Date,Narration,Chq./Ref.No.,Value Dt,Withdrawal Amt.,Deposit Amt.,Closing Balance",
  "csvHeaderMap": {
    "Date": "date",
    "Narration": "description",
    "Chq./Ref.No.": "ref",
    "Chq/Ref No": "ref",
    "Value Dt": "value_date",
    "Value Date": "value_date",
    "Withdrawal Amt.": "debit",
    "Withdrawal Amt": "debit",
    "Deposit Amt.": "credit",
    "Deposit Amt": "credit",
    "Closing Balance": "balance"
  },
  "csvExample": "Date,Narration,Chq./Ref.No.,Value Dt,Withdrawal Amt.,Deposit Amt.,Closing Balance\n28/03/2026,TRANSFER - Pushpa C K,UTIN123456789,28/03/26,150000.00,,313384.91\n28/03/2026,UPI - Cane Recipes,UPI12345678,28/03/26,165.00,,463384.91\n28/03/2026,TRANSFER - Jawahar Reddy,NEFT987654321,28/03/26,,15000.00,463721.91"
}
